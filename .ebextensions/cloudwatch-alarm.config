Resources:
  CPUAlarmHigh:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName: "freshbasket-cpu-high"
      AlarmDescription: "CPU utilisation exceeded 80% for 5 consecutive minutes — possible traffic spike or runaway process"
      MetricName: CPUUtilization
      Namespace: AWS/EC2
      Statistic: Average
      Period: 300
      EvaluationPeriods: 1
      Threshold: 80
      ComparisonOperator: GreaterThanThreshold
      Dimensions:
        - Name: AutoScalingGroupName
          Value: { "Ref": "AWSEBAutoScalingGroup" }
      AlarmActions:
        - "arn:aws:sns:us-east-1:055842546826:ElasticBeanstalkNotifications-Environment-Freshbasket-idb-env"
      OKActions:
        - "arn:aws:sns:us-east-1:055842546826:ElasticBeanstalkNotifications-Environment-Freshbasket-idb-env"
      TreatMissingData: notBreaching
